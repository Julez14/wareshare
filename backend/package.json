{
  "name": "wareshare-api",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "tail": "wrangler tail",
    "db:migrate": "wrangler d1 execute wareshare-db --file=./src/db/schema.sql",
    "db:migrate:local": "wrangler d1 execute wareshare-db --local --file=./src/db/schema.sql",
    "db:seed": "wrangler d1 execute wareshare-db --local --file=./src/db/seed.sql",
    "db:seed:remote": "wrangler d1 execute wareshare-db --remote --file=./src/db/seed.sql",
    "db:clean": "node -e \"const {rmSync}=require('fs');rmSync('.wrangler/state/v3/d1',{recursive:true,force:true})\"",
    "db:reset": "npm run db:clean && wrangler d1 execute wareshare-db --local --file=./src/db/schema.sql && wrangler d1 execute wareshare-db --local --file=./src/db/seed.sql",
    "cf-typegen": "wrangler types",
    "test": "npx tsx scripts/test-endpoints.ts",
    "test:remote": "npx tsx scripts/test-endpoints.ts",
    "test:local": "cross-env TEST_BASE_URL=http://localhost:8787 npx tsx scripts/test-endpoints.ts",
    "test:edge": "npx tsx scripts/test-edge-cases.ts",
    "test:edge:local": "cross-env TEST_BASE_URL=http://localhost:8787 npx tsx scripts/test-edge-cases.ts"
  },
  "dependencies": {
    "hono": "^4.7.4",
    "ulid": "^3.0.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20250310.0",
    "cross-env": "^10.1.0",
    "typescript": "^5.8.2",
    "wrangler": "^4.4.0"
  }
}
