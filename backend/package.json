{
  "name": "wareshare-api",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "tail": "wrangler tail",
    "db:migrate": "wrangler d1 migrations apply wareshare-db --remote",
    "db:migrate:local": "wrangler d1 migrations apply wareshare-db --local",
    "db:migration:create": "wrangler d1 migrations create wareshare-db",
    "db:seed": "wrangler d1 execute wareshare-db --local --file=./src/db/seed.sql",
    "db:seed:remote": "wrangler d1 execute wareshare-db --remote --file=./src/db/seed.sql",
    "db:reset": "wrangler d1 migrations apply wareshare-db --local && wrangler d1 execute wareshare-db --local --file=./src/db/seed.sql",
    "cf-typegen": "wrangler types",
    "test": "npx tsx scripts/test-endpoints.ts",
    "test:remote": "npx tsx scripts/test-endpoints.ts"
  },
  "dependencies": {
    "hono": "^4.7.4",
    "ulid": "^3.0.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20250310.0",
    "typescript": "^5.8.2",
    "wrangler": "^4.4.0"
  }
}
